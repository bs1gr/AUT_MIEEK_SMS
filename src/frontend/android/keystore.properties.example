# Copy this file to keystore.properties and fill in your local signing credentials.
# keystore.properties is gitignored — never commit the real file.
#
# For CI builds, use GitHub Actions secrets instead (see build.gradle signingConfigs):
#   KEYSTORE_PATH, KEYSTORE_PASSWORD, KEY_ALIAS, KEY_PASSWORD
#
storeFile=/path/to/your/sms-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=sms-release
keyPassword=YOUR_KEY_PASSWORD
