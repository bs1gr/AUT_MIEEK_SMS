<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext HTTP globally: this app connects to private networks (Tailscale VPN,
         LAN) where HTTP is acceptable — Tailscale encrypts the tunnel at the OS level. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext HTTP for all private/VPN destinations.
         Tailscale (100.x.x.x), LAN (192.168.x.x), and localhost all use HTTP.
         Tailscale itself encrypts the tunnel, so cleartext at the app layer is safe. -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator host -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Localhost for on-device dev server or standalone mode -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- School internal LAN server (ΜΙΕΕΚ network 172.16.0.0/24) -->
        <domain includeSubdomains="false">172.16.0.19</domain>
    </domain-config>
</network-security-config>
