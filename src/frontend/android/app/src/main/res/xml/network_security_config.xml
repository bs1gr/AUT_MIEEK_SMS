<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Block cleartext HTTP by default (Android 9+ already does this, but explicit is better) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext HTTP only for known local/development destinations -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator host -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Localhost for on-device dev server or standalone mode -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- School internal LAN server (ΜΙΕΕΚ network 172.16.0.0/24) -->
        <domain includeSubdomains="false">172.16.0.19</domain>
    </domain-config>
</network-security-config>
