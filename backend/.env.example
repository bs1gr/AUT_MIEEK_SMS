# Environment Configuration - SQLite Default (Development)
# Copy this to .env and customize for your setup

# ==================== APPLICATION ====================
APP_NAME=Student Management System
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development
SMS_ENV=development
SMS_EXECUTION_MODE=native

# ==================== API SETTINGS ====================
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=True

# ==================== DATABASE ====================
# Development: SQLite (fast, local, no network)
# Production: Change DATABASE_ENGINE to postgresql and fill POSTGRES_* below
DATABASE_ENGINE=sqlite

# PostgreSQL configuration (for production use only)
# Uncomment and fill these to switch to QNAP PostgreSQL
# DATABASE_ENGINE=postgresql
POSTGRES_HOST=172.16.0.2
POSTGRES_PORT=55433
POSTGRES_DB=student_management
POSTGRES_USER=sms_user
POSTGRES_PASSWORD=your-password-here
POSTGRES_SSLMODE=prefer
POSTGRES_OPTIONS=connect_timeout=30&application_name=sms

# ==================== SECURITY ====================
SECRET_KEY=bMkIBaq8m7OldFdIJtuYHQvEGdEAuHyl1zl3C/k2s8iALqzVLrsA0+EwljqvQKL4
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== AUTHENTICATION ====================
AUTH_ENABLED=True
AUTH_MODE=permissive

# Admin account (auto-created on startup)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=AdminPassword123!
DEFAULT_ADMIN_FULL_NAME=System Administrator

# ==================== CORS SETTINGS ====================
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://localhost
CORS_CREDENTIALS=True

# ==================== OTHER ====================
LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=True
ENABLE_CACHE=True
CACHE_TTL=300
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Student Management System
