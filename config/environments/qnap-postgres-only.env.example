# QNAP PostgreSQL-Only Deployment (for shared DB with VPS app runtime)
# Verified QNAP ARMv7 baseline image: arm32v7/postgres:14-bullseye
#
# Steps:
# 1) Copy to .env.qnap.postgres-only
# 2) Set all <CHANGE_ME> values
# 3) Start with:
#    docker compose -f docker/docker-compose.qnap.postgres-only.yml --env-file .env.qnap.postgres-only up -d

# Database identity
POSTGRES_USER=sms_user
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
POSTGRES_DB=student_management

# QNAP bind path for persistent DB data
QNAP_POSTGRES_DATA_PATH=/share/Container/sms-postgres
QNAP_POSTGRES_BACKUP_PATH=/share/Container/sms-backups
QNAP_POSTGRES_BACKUP_KEEP=14

# Host binding for PostgreSQL port
# IMPORTANT:
# - Use a private/VPN interface IP (recommended), not public internet exposure.
# - Example Tailscale/WireGuard IP: 100.x.x.x or 10.x.x.x
QNAP_PG_BIND_IP=<CHANGE_ME_PRIVATE_OR_VPN_IP>
QNAP_PG_PORT=55433

# Optional DB tuning
POSTGRES_MAX_CONNECTIONS=150
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_LOG_MIN_DURATION_MS=300

# For app runtime (VPS/backend), prefer DATABASE_ENGINE=postgresql + POSTGRES_* values.
# If you need a raw URL, the app-compatible format is:
# DATABASE_URL=postgresql+psycopg://sms_user:<PASSWORD>@<QNAP_PRIVATE_OR_VPN_IP>:55433/student_management
